# Full setup docs: https://capp3.github.io/actual_starling_connector/configuration/
# (or: just docs-serve). This file is the exhaustive env var reference.
#
# Shared Actual server (required)
ACTUAL_SERVER_URL=https://actual.example.com
ACTUAL_SYNC_PASSWORD=replace-me
ACTUAL_BUDGET_SYNC_ID=replace-with-sync-id-from-actual-settings

# Sync channels — configure at least one full pair (token + Actual account).
# Individual and joint use separate Starling personal access tokens.
STARLING_INDIVIDUAL_ACCESS_TOKEN=replace-me
ACTUAL_INDIVIDUAL_ACCOUNT_ID=replace-with-actual-account-id-or-name

# STARLING_JOINT_ACCESS_TOKEN=replace-me
# ACTUAL_JOINT_ACCOUNT_ID=replace-with-joint-actual-account-id-or-name

# Optional (local/host defaults shown)
ACTUAL_DATA_DIR=data/actual
# Required if the Actual budget file is end-to-end encrypted:
# ACTUAL_ENCRYPTION_PASSWORD=
SYNC_INTERVAL_MINUTES=60
LOG_LEVEL=INFO
DATABASE_PATH=data/sync.db
TIMEZONE=UTC

# Docker Compose overrides these to persistent volume paths:
#   DATABASE_PATH=/data/sync.db
#   ACTUAL_DATA_DIR=/data/actual

# If Actual is behind Cloudflare Access, create a Service Token and set both:
# ACTUAL_CF_ACCESS_CLIENT_ID=
# ACTUAL_CF_ACCESS_CLIENT_SECRET=
# Or point ACTUAL_SERVER_URL at an internal URL that bypasses Access.

# Optional Docker secrets: path to a file whose contents are the secret.
# STARLING_INDIVIDUAL_ACCESS_TOKEN_FILE=/run/secrets/starling_individual_access_token
# STARLING_JOINT_ACCESS_TOKEN_FILE=/run/secrets/starling_joint_access_token
# ACTUAL_SERVER_URL_FILE=/run/secrets/actual_server_url
# ACTUAL_SYNC_PASSWORD_FILE=/run/secrets/actual_sync_password
# ACTUAL_ENCRYPTION_PASSWORD_FILE=/run/secrets/actual_encryption_password
# ACTUAL_CF_ACCESS_CLIENT_ID_FILE=/run/secrets/actual_cf_access_client_id
# ACTUAL_CF_ACCESS_CLIENT_SECRET_FILE=/run/secrets/actual_cf_access_client_secret
